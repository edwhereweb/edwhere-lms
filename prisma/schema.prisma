generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  ADMIN
  TEACHER
  STUDENT
  MARKETER
}

enum PurchaseOnboardingSource {
  MANUAL
  PAID
  PAID_MANUAL
}

model Profile {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique
  name String
  imageUrl String?  
  email String  

  role MemberRole @default(STUDENT)
  lastLoginAt DateTime?
  lastLoginIp String?
  courseInstructors CourseInstructor[]
  courseMessages    CourseMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  userId          String
  title           String
  description     String?
  imageUrl        String?
  imageAlt        String?
  price           Float?
  isPublished     Boolean    @default(false)
  pendingApproval Boolean    @default(false)
  isWebVisible    Boolean    @default(true)
  slug            String?
  metaTitle       String?
  metaDescription String?

  categoryId  String?    @db.ObjectId
  category    Category?  @relation(fields: [categoryId], references: [id])
  attachments Attachment[]
  modules     Module[]
  chapters    Chapter[]
  purchases   Purchase[]
  instructors CourseInstructor[]
  messages    CourseMessage[]
  blogTagMappings BlogTagMapping[]

  blogPostIds     String[]   @db.ObjectId
  blogPosts       BlogPost[] @relation(fields: [blogPostIds], references: [id])

  createdAt   DateTime   @default(now())

  updatedAt   DateTime   @updatedAt

  @@index([categoryId])
  @@fulltext([title])
}

model Attachment {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  url       String

  courseId  String     @db.ObjectId
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([courseId])
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  courses   Course[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CourseInstructor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId  String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  profileId String   @db.ObjectId
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, profileId])
  @@index([courseId])
  @@index([profileId])
}

model Quiz {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  chapterId       String      @unique @db.ObjectId
  chapter         Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  isGraded        Boolean     @default(false)
  timeLimit       Int?        // in minutes
  randomize       Boolean     @default(false)
  maxTabSwitches  Int?
  passScore       Float?      // minimum % to pass (e.g. 60.0)
  maxAttempts     Int         @default(1)

  questions       Question[]
  attempts        QuizAttempt[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Question {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  quizId           String       @db.ObjectId
  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  body             String
  imageUrl         String?
  options          String[]
  correctOptions   Int[]
  isMultipleChoice Boolean      @default(false)

  responses        QuestionResponse[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([quizId])
}

model QuizAttempt {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  quizId      String             @db.ObjectId
  quiz        Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  startTime   DateTime           @default(now())
  submittedAt DateTime?
  score       Float?
  tabSwitches Int                @default(0)
  isCompleted Boolean            @default(false)

  responses   QuestionResponse[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([quizId])
  @@index([userId])
}

model QuestionResponse {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  attemptId       String       @db.ObjectId
  attempt         QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String       @db.ObjectId
  question        Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptions Int[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model Module {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  position    Int
  isPublished Boolean    @default(false)
  isFree      Boolean    @default(false)

  courseId    String     @db.ObjectId
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  chapters    Chapter[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([courseId])
}

model Chapter {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  videoUrl    String?
  youtubeVideoId String?
  content     String?
  htmlContent String?
  gamifiedFlag String?
  pdfUrl      String?
  contentType String?   @default("VIDEO_MUX")
  position    Int
  isPublished Boolean    @default(false)
  isFree      Boolean    @default(false)
  isLibraryAsset Boolean @default(false)

  muxData     MuxData?
  quiz        Quiz?

  courseId    String     @db.ObjectId
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  moduleId    String?    @db.ObjectId
  module      Module?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  userProgress UserProgress[]
  projectSubmissions ProjectSubmission[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([courseId])
  @@index([moduleId])
}

model MuxData {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  assetId     String
  playbackId  String?
  muxUploadId String?

  chapterId   String     @unique @db.ObjectId
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String

  chapterId   String     @db.ObjectId
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  isCompleted Boolean    @default(false)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([chapterId])
  @@unique([userId, chapterId])
}


model Purchase {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  onboardingSource PurchaseOnboardingSource?

  courseId    String     @db.ObjectId
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
}

model RazorpayCustomer {
  id                  String     @id @default(auto()) @map("_id") @db.ObjectId
  userId              String     @unique
  razorpayCustomerId  String     @unique

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Logging {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  method    String
  body      String?
  response  String?
  statusCode Int?
  errorMessage String?
  createdAt DateTime @default(now())
}

model Lead {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  phone      String
  email      String
  message    String
  source     String   @default("GENERAL_WEBSITE_ENQUIRY")
  status     String   @default("DECISION_PENDING")
  notes      String?
  assignedTo String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([source])
}

model CourseMessage {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  content  String

  courseId         String  @db.ObjectId
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  authorId         String  @db.ObjectId
  author           Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Which student's private thread this message belongs to
  threadStudentId  String  @db.ObjectId

  createdAt DateTime @default(now())

  @@index([courseId])
  @@index([courseId, threadStudentId])
}

model MentorLastRead {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  instructorId String   @db.ObjectId
  courseId     String   @db.ObjectId
  studentId    String?  @db.ObjectId   // optional to handle legacy null records
  lastReadAt   DateTime @default(now())

  @@unique([instructorId, courseId, studentId])
  @@index([instructorId])
}

model StudentLastRead {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String   @db.ObjectId
  courseId   String   @db.ObjectId
  lastReadAt DateTime @default(now())

  @@unique([studentId, courseId])
  @@index([studentId])
}

model ProjectSubmission {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  driveUrl   String
  status     String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewNote String?
  reviewedAt DateTime?
  reviewedBy String?

  chapterId  String    @db.ObjectId
  chapter    Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, chapterId])
  @@index([chapterId])
  @@index([status])
}

model BlogAuthor {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @unique
  name        String
  bio         String?
  imageUrl    String?
  role        String?
  credentials String[] // e.g. ["EC-Council CEH", "ISO 27001 Auditor"]

  posts       BlogPost[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogCategory {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String       @unique
  content         String       // Markdown or HTML
  imageUrl        String?
  imageAlt        String?
  isPublished     Boolean      @default(false)
  
  metaTitle       String?
  metaDescription String?
  tags            String[]     // For dynamic course mapping

  courseIds       String[]     @db.ObjectId
  courses         Course[]     @relation(fields: [courseIds], references: [id])

  authorId        String       @db.ObjectId
  author          BlogAuthor   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId      String?      @db.ObjectId
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([authorId])
  @@index([categoryId])
}

model BlogTagMapping {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tagName   String   @unique // The tag to match (e.g. "IoT")
  courseId  String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}