generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  ADMIN
  TEACHER
  STUDENT
  MARKETER
  BLOGGER
}

enum PurchaseOnboardingSource {
  MANUAL
  PAID
  PAID_MANUAL
  BATCH_ENROLLMENT
}

model Profile {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique
  name String
  imageUrl String?  
  email String  

  role MemberRole @default(STUDENT)
  lastLoginAt DateTime?
  lastLoginIp String?
  courseInstructors CourseInstructor[]
  courseMessages    CourseMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  userId          String
  title           String
  description     String?
  imageUrl        String?
  imageAlt        String?
  price           Float?
  isPublished     Boolean    @default(false)
  pendingApproval Boolean    @default(false)
  isWebVisible    Boolean    @default(true)
  slug            String?
  metaTitle       String?
  metaDescription String?

  // Admin-only toggle: permits offline sessions to be scheduled on the same day
  allowSameDayOfflineSession Boolean @default(false)

  categoryId  String?    @db.ObjectId
  category    Category?  @relation(fields: [categoryId], references: [id])
  attachments Attachment[]
  modules     Module[]
  chapters    Chapter[]
  purchases   Purchase[]
  instructors CourseInstructor[]
  messages    CourseMessage[]
  blogTagMappings BlogTagMapping[]
  batches     BatchCourse[]

  blogPostIds     String[]   @db.ObjectId
  blogPosts       BlogPost[] @relation(fields: [blogPostIds], references: [id])

  createdAt   DateTime   @default(now())

  updatedAt   DateTime   @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@fulltext([title])
}

model Attachment {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  url       String

  courseId  String     @db.ObjectId
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([courseId])
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  courses   Course[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CourseInstructor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId  String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  profileId String   @db.ObjectId
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, profileId])
  @@index([courseId])
  @@index([profileId])
}

model Quiz {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  chapterId       String      @unique @db.ObjectId
  chapter         Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  isGraded        Boolean     @default(false)
  timeLimit       Int?        // in minutes
  randomize       Boolean     @default(false)
  maxTabSwitches  Int?
  passScore       Float?      // minimum % to pass (e.g. 60.0)
  maxAttempts     Int         @default(1)

  questions       Question[]
  attempts        QuizAttempt[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Question {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  quizId           String       @db.ObjectId
  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  body             String
  imageUrl         String?
  options          String[]
  correctOptions   Int[]
  isMultipleChoice Boolean      @default(false)

  responses        QuestionResponse[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([quizId])
}

model QuizAttempt {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  quizId      String             @db.ObjectId
  quiz        Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  startTime   DateTime           @default(now())
  submittedAt DateTime?
  score       Float?
  tabSwitches Int                @default(0)
  isCompleted Boolean            @default(false)

  responses   QuestionResponse[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([quizId])
  @@index([userId])
}

model QuestionResponse {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  attemptId       String       @db.ObjectId
  attempt         QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String       @db.ObjectId
  question        Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptions Int[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model Module {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  position    Int
  isPublished Boolean    @default(false)
  isFree      Boolean    @default(false)

  courseId    String     @db.ObjectId
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  chapters    Chapter[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([courseId])
}

model Chapter {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  videoUrl    String?
  youtubeVideoId String?
  content     String?
  htmlContent String?
  gamifiedFlag String?
  pdfUrl      String?
  contentType String?   @default("VIDEO_MUX")
  position    Int
  isPublished Boolean    @default(false)
  isFree      Boolean    @default(false)
  isLibraryAsset Boolean @default(false)

  muxData     MuxData?
  quiz        Quiz?

  courseId    String     @db.ObjectId
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  moduleId    String?    @db.ObjectId
  module      Module?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  userProgress UserProgress[]
  projectSubmissions ProjectSubmission[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([courseId])
  @@index([moduleId])
}

model MuxData {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  assetId     String
  playbackId  String?
  muxUploadId String?

  chapterId   String     @unique @db.ObjectId
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String

  chapterId   String     @db.ObjectId
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  isCompleted Boolean    @default(false)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([chapterId])
  @@unique([userId, chapterId])
}


model Purchase {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  onboardingSource PurchaseOnboardingSource?

  courseId    String     @db.ObjectId
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
}

model RazorpayCustomer {
  id                  String     @id @default(auto()) @map("_id") @db.ObjectId
  userId              String     @unique
  razorpayCustomerId  String     @unique

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Logging {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  method    String
  body      String?
  response  String?
  statusCode Int?
  errorMessage String?
  createdAt DateTime @default(now())
}

model Lead {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  phone      String
  email      String
  message    String
  source     String   @default("GENERAL_WEBSITE_ENQUIRY")
  status     String   @default("DECISION_PENDING")
  notes      String?
  assignedTo String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([source])
}

model CourseMessage {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  content  String

  courseId         String  @db.ObjectId
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  authorId         String  @db.ObjectId
  author           Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Which student's private thread this message belongs to
  threadStudentId  String  @db.ObjectId

  createdAt DateTime @default(now())

  @@index([courseId])
  @@index([courseId, threadStudentId])
}

model MentorLastRead {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  instructorId String   @db.ObjectId
  courseId     String   @db.ObjectId
  studentId    String?  @db.ObjectId   // optional to handle legacy null records
  lastReadAt   DateTime @default(now())

  @@unique([instructorId, courseId, studentId])
  @@index([instructorId])
}

model StudentLastRead {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String   @db.ObjectId
  courseId   String   @db.ObjectId
  lastReadAt DateTime @default(now())

  @@unique([studentId, courseId])
  @@index([studentId])
}

model ProjectSubmission {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  driveUrl   String
  status     String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewNote String?
  reviewedAt DateTime?
  reviewedBy String?

  chapterId  String    @db.ObjectId
  chapter    Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, chapterId])
  @@index([chapterId])
  @@index([status])
}

model BlogAuthor {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @unique
  name        String
  bio         String?
  imageUrl    String?
  role        String?
  credentials String[] // e.g. ["EC-Council CEH", "ISO 27001 Auditor"]
  linkedinUrl String?
  twitterUrl  String?
  websiteUrl  String?

  posts       BlogPost[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogCategory {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String       @unique
  content         String       // Markdown or HTML
  imageUrl        String?
  imageAlt        String?
  isPublished     Boolean      @default(false)
  
  metaTitle       String?
  metaDescription String?
  tags            String[]     // For dynamic course mapping

  courseIds       String[]     @db.ObjectId
  courses         Course[]     @relation(fields: [courseIds], references: [id])

  authorId        String       @db.ObjectId
  author          BlogAuthor   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId      String?      @db.ObjectId
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([authorId])
  @@index([categoryId])
  @@index([isPublished])
}

model BlogTagMapping {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tagName   String   @unique // The tag to match (e.g. "IoT")
  courseId  String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

// ── Offline Batches ──────────────────────────────────────────────────────

model Batch {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?

  // Clerk userId of the admin/teacher who created this batch
  createdBy   String

  // Admin-only toggle: permits offline sessions to be scheduled on the same day for this batch
  allowSameDayOfflineSession Boolean @default(false)

  courses     BatchCourse[]
  enrollments BatchEnrollment[]
  modules     BatchModule[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdBy])
}

model BatchCourse {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  batchId  String  @db.ObjectId
  batch    Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  courseId String  @db.ObjectId
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([batchId, courseId])
  @@index([batchId])
  @@index([courseId])
}

model BatchEnrollment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  batchId    String   @db.ObjectId
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  // Clerk userId of the enrolled student
  userId     String

  // Clerk userId of the admin/instructor who performed the enrollment
  enrolledBy String
  
  // Gamification Stats
  attendanceStreak Int    @default(0)
  totalMcqScore    Int    @default(0)
  totalMcqPossible Int    @default(0)

  createdAt  DateTime @default(now())

  @@unique([batchId, userId])
  @@index([batchId])
  @@index([userId])
}

// ── Batch Content Structure ───────────────────────────────────────────────

enum BatchItemType {
  OFFLINE_SESSION
  PDF
  RESOURCE_LINK
  TASK
}

enum BatchSubmissionType {
  OFFLINE
  ONLINE
}

model BatchModule {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  batchId   String      @db.ObjectId
  batch     Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title     String
  position  Int         @default(0)
  items     BatchItem[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([batchId])
}

model BatchItem {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String        @db.ObjectId
  module      BatchModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type        BatchItemType
  title       String
  position    Int           @default(0)

  // PDF content
  pdfUrl      String?

  // Resource link content
  resourceUrl String?

  // Task content (1-to-1 relation)
  task        BatchTask?

  // Offline session content (1-to-1 relation)
  session     OfflineSession?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([moduleId])
}

model BatchTask {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  itemId         String               @unique @db.ObjectId
  item           BatchItem            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  description    String
  maxMarks       Float
  submissionType BatchSubmissionType

  submissions    BatchTaskSubmission[]

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model BatchTaskSubmission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  taskId    String    @db.ObjectId
  task      BatchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Clerk userId of the student
  userId    String

  // Populated by student for ONLINE tasks
  driveLink String?

  // Populated by instructor for both types
  marks     Float?
  gradedBy  String?
  gradedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// ── Offline Session ─────────────────────────────────────────────────────

model OfflineSession {
  id              String               @id @default(auto()) @map("_id") @db.ObjectId
  itemId          String               @unique @db.ObjectId
  item            BatchItem            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  scheduledAt     DateTime
  durationMinutes Int                  @default(60)
  location        String?
  meetLink        String?

  // Clerk userId of the primary instructor
  instructorId    String

  // Set by instructor when the session ends; starts the 30-min MCQ window
  completedAt     DateTime?

  // Set when attendance is manually submitted or auto-submitted at +15m
  attendanceSubmittedAt DateTime?

  coInstructors   SessionCoInstructor[]
  uploads         SessionUpload[]
  mcq             SessionMcq?
  attendances     SessionAttendance[]
  feedback        SessionFeedback?
  studentFeedback StudentSessionFeedback[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([instructorId])
}

model SessionCoInstructor {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String         @db.ObjectId
  session   OfflineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Clerk userId of the co-instructor
  userId    String
  createdAt DateTime       @default(now())

  @@unique([sessionId, userId])
  @@index([sessionId])
}

enum SessionAttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

model SessionAttendance {
  id          String                  @id @default(auto()) @map("_id") @db.ObjectId
  sessionId   String                  @db.ObjectId
  session     OfflineSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String
  status      SessionAttendanceStatus
  remarks     String?
  markedAt    DateTime                @default(now())

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

enum SessionUploadStatus {
  APPROVED
  PENDING
  REJECTED
}

model SessionUpload {
  id         String              @id @default(auto()) @map("_id") @db.ObjectId
  sessionId  String              @db.ObjectId
  session    OfflineSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // "slides" or "notes"
  type       String
  fileUrl    String
  filename   String
  status     SessionUploadStatus @default(APPROVED)

  uploadedBy String
  approvedBy String?
  approvedAt DateTime?

  logs       SessionUploadLog[]

  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([sessionId])
  @@index([status])
}

// One record per upload attempt. Used to count and log late upload events.
model SessionUploadLog {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  uploadId   String        @db.ObjectId
  upload     SessionUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  isLate     Boolean
  uploadedAt DateTime      @default(now())
  uploadedBy String

  @@index([uploadId])
}

model SessionMcq {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  sessionId   String               @unique @db.ObjectId
  session     OfflineSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title       String               @default("Session MCQ")
  questions   SessionMcqQuestion[]
  submissions SessionMcqSubmission[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model SessionMcqQuestion {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  mcqId         String     @db.ObjectId
  mcq           SessionMcq @relation(fields: [mcqId], references: [id], onDelete: Cascade)
  body          String
  options       String[]
  correctOption Int
  position      Int        @default(0)

  createdAt     DateTime   @default(now())

  @@index([mcqId])
}

model SessionMcqSubmission {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  mcqId       String     @db.ObjectId
  mcq         SessionMcq @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  // Clerk userId of the student
  userId      String

  // Answers in shuffled display order (parallel to shuffleMap stored in submission)
  answers     Int[]

  // Indices mapping displayPosition → originalPosition (stored so scores can be re-verified)
  shuffleMap  Int[]

  score       Int
  total       Int

  submittedAt DateTime   @default(now())

  @@unique([mcqId, userId])
  @@index([mcqId])
  @@index([userId])
}

// ── Post-Session Instructor Feedback & IE Score ──────────────────────────

model SessionFeedback {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  sessionId   String         @unique @db.ObjectId
  session     OfflineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Qualitative — exactly 3 entries each
  wentWell    String[]
  wentWrong   String[]

  // Quantitative metrics (0–10 each)
  askingQuestions    Float
  answeringQuickly   Float
  groupTalk          Float
  classPace          Float
  understandingIdeas Float
  doingTheWork       Float
  fixingMistakes     Float
  memory             Float
  goalCompletion     Float

  // Derived IE Score (0–100)
  ieScore     Float

  // Clerk userId of the instructor who submitted the form
  submittedBy String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
// ── Landing Pages ──────────────────────────────────────────────────────────

model LandingPage {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String   @unique
  htmlContent     String   // The full HTML for the page
  isPublished     Boolean  @default(false)
  isApproved      Boolean  @default(false)
  
  createdBy       String   // Clerk userId
  approvedBy      String?  // Clerk userId of admin who approved
  approvedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdBy])
  @@index([isApproved])
}

// ── Post-Session Student Feedback ──────────────────────────

model StudentSessionFeedback {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  sessionId       String         @db.ObjectId
  session         OfflineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String         // Clerk Student ID (stored for validation, but not shown to teachers)
  
  // Star Ratings (1-5)
  instructorRating Int
  materialRating   Int
  activityRating   Int
  overallRating    Int
  
  // Pace Rating (1: Too Slow, 3: Perfect, 5: Too Fast)
  paceRating       Int

  // Qualitative
  likedMost        String?
  improvement      String?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([sessionId, userId])
  @@index([sessionId])
}

// ── Certificates ──────────────────────────

model Certificate {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  credentialId      String   @unique
  recipientName     String
  courseName        String
  duration          String
  deliveryMode      String
  dateOfAchievement String   // Stored as YYYY-MM-DD for exact matching
  
  issuedByUserId    String   // Clerk userId of admin
  score             Float?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── Gamification ──────────────────────────

model UserProgressStats {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique
  totalXp         Int      @default(0)
  currentLevel    Int      @default(1)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActiveAt    DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Badge {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String      @unique
  description String
  icon        String      
  
  users       UserBadge[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model UserBadge {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  badgeId   String   @db.ObjectId
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}
